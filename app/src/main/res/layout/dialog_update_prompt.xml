<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <!-- Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="⬆️"
            android:textSize="60sp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Update Available"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Version arrow -->
        <TextView
            android:id="@+id/tv_update_dialog_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <!-- Release notes card (hidden when empty) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_update_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/auros_abyss">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHAT'S NEW"
                    style="@style/Widget.Auros.Eyebrow"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_update_dialog_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="8"
                    android:ellipsize="end" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary: Download & Install -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_download"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Download &amp; Install"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Secondary: Update Later -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_later"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Update Later"
            android:textSize="15sp"
            android:layout_marginBottom="6dp" />

        <!-- Tertiary: Don't Update (muted text, clearly destructive intent) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_skip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Don't Update"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>
</ScrollView>
