<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Overview graphs (UX1): aggregate trends across all sessions, rendered programmatically.
             Placed above the per-session recap so the tab opens on the visual trend story.
             Hidden entirely when there are no sessions (the empty state below covers that case). -->
        <LinearLayout
            android:id="@+id/layout_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Session selector -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_session"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Session"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <AutoCompleteTextView
                android:id="@+id/ac_session"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Empty / first-time state -->
        <TextView
            android:id="@+id/tv_recap_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No sessions yet. Complete a workout to see your recap."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingVertical="24dp"
            android:visibility="gone" />

        <!-- Programmatically-built recap sections -->
        <LinearLayout
            android:id="@+id/layout_recap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
