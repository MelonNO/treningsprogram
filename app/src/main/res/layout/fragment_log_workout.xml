<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?android:attr/colorBackground">

    <!-- Header bar: counter + elapsed + pause button + progress -->
    <!-- B01: the whole jump-menu tap target is this clickable container (counter row +
         progress bar). Tapping anywhere on/around the bar or its counter opens the
         exercise-jump menu — a forgiving hit area, not just the thin bar/label. The
         pause button is a child that consumes its own taps, so it still works. -->
    <LinearLayout
        android:id="@+id/layout_session_progress"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="12dp" android:paddingBottom="12dp"
        android:clickable="true" android:focusable="true"
        android:background="?attr/selectableItemBackground">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tv_exercise_counter"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface" />
            <TextView android:id="@+id/tv_elapsed"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="4dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pause_workout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕"
                android:textSize="16sp"
                android:minWidth="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp" />
        </LinearLayout>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_session"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="100" app:trackCornerRadius="4dp" app:trackColor="#2A2A3A" />
    </LinearLayout>

    <!-- Scrollable main content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Exercise info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardElevation="0dp"
                app:cardCornerRadius="16dp" app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Main row: info on left, thumbnail on right -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="top"
                        android:layout_marginBottom="10dp">

                        <!-- Left column: name, chips, timers, last session, freestyle -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginEnd="12dp">

                            <!-- name row -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">
                                <TextView android:id="@+id/tv_muscle_badge"
                                    android:layout_width="wrap_content" android:layout_height="44dp"
                                    android:minWidth="44dp"
                                    android:paddingStart="8dp" android:paddingEnd="8dp"
                                    android:gravity="center" android:textSize="9sp" android:textStyle="bold"
                                    android:background="@drawable/bg_achievement_icon"
                                    android:layout_marginEnd="12dp" />
                                <TextView android:id="@+id/tv_exercise_name"
                                    android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textColor="?attr/colorOnSurface" />
                            </LinearLayout>

                            <!-- target chips row -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:layout_marginBottom="6dp">
                                <TextView android:id="@+id/chip_target_sets"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:paddingTop="4dp" android:paddingBottom="4dp"
                                    android:textSize="12sp" android:textStyle="bold"
                                    android:textColor="#7C67F5" android:background="@drawable/bg_spec_chip" />
                                <TextView android:id="@+id/chip_target_reps"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:paddingTop="4dp" android:paddingBottom="4dp"
                                    android:textSize="12sp" android:textStyle="bold"
                                    android:textColor="#7C67F5" android:background="@drawable/bg_spec_chip" />
                                <TextView android:id="@+id/chip_target_weight"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:paddingTop="4dp" android:paddingBottom="4dp"
                                    android:textSize="12sp" android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" android:background="@drawable/bg_spec_chip" />
                            </LinearLayout>

                            <!-- per-exercise elapsed timer -->
                            <TextView android:id="@+id/tv_exercise_time"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <!-- last session reference (Item 8: cleaner formatting) -->
                            <TextView android:id="@+id/tv_last_session"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:lineSpacingExtra="2dp"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="#8888A8" android:visibility="gone" />

                            <!-- Freestyle exercise name input (hidden in guided mode) -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/til_freestyle_exercise"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:hint="Exercise name"
                                android:visibility="gone"
                                android:layout_marginTop="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_freestyle_exercise"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="textCapWords|textNoSuggestions"
                                    android:imeOptions="actionDone"
                                    android:privateImeOptions="nm" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <!-- Right: thumbnail (tap to view full screen with dimmed background) -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="88dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutlineVariant">
                            <FrameLayout
                                android:id="@+id/layout_muscle_banner"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#1C1C2A"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground">
                                <TextView
                                    android:id="@+id/tv_muscle_banner_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05"
                                    android:gravity="center"
                                    android:padding="4dp"
                                    android:textColor="?attr/colorOnSurface" />
                                <ImageView
                                    android:id="@+id/iv_exercise_image"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:visibility="gone"
                                    android:contentDescription="Exercise image" />
                                <TextView
                                    android:id="@+id/tv_image_expand_hint"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|end"
                                    android:layout_margin="4dp"
                                    android:padding="2dp"
                                    android:text="⛶"
                                    android:textSize="11sp"
                                    android:textColor="#AAFFFFFF"
                                    android:background="#44000000"
                                    android:visibility="gone" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Set logging card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardElevation="0dp"
                app:cardCornerRadius="16dp" app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- top row: warmup toggle -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_warmup"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Warm-up" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    </LinearLayout>

                    <!-- weight + reps inputs with +/- buttons -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <!-- Weight -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginEnd="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Weight (kg)" android:textSize="11sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginBottom="4dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_weight_minus"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="36dp" android:layout_height="36dp"
                                    android:text="-" android:textSize="16sp"
                                    android:minWidth="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_weight"
                                    android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:inputType="numberDecimal"
                                    android:imeOptions="actionDone"
                                    android:gravity="center"
                                    android:textSize="20sp" android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:textColorHint="?attr/colorOnSurfaceVariant"
                                    android:hint="BW"
                                    android:background="@null"
                                    android:padding="6dp" />
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_weight_plus"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="36dp" android:layout_height="36dp"
                                    android:text="+" android:textSize="16sp"
                                    android:minWidth="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Reps -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Reps" android:textSize="11sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginBottom="4dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_reps_minus"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="36dp" android:layout_height="36dp"
                                    android:text="-" android:textSize="16sp"
                                    android:minWidth="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_reps"
                                    android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:inputType="number"
                                    android:imeOptions="actionDone"
                                    android:gravity="center"
                                    android:textSize="20sp" android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:background="@null"
                                    android:padding="6dp" />
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_reps_plus"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="36dp" android:layout_height="36dp"
                                    android:text="+" android:textSize="16sp"
                                    android:minWidth="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- RPE row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Effort: " android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="8dp" />
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cg_rpe"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            app:singleSelection="true" app:selectionRequired="false">
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_rpe_easy"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Easy" android:textSize="12sp" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_rpe_moderate"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Moderate" android:textSize="12sp" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_rpe_hard"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hard" android:textSize="12sp" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>

                    <!-- Set counter -->
                    <TextView
                        android:id="@+id/tv_set_counter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="10dp" />

                    <!-- Log Set button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_log_set"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="LOG SET"
                        android:textSize="16sp" android:textStyle="bold"
                        android:letterSpacing="0.05" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logged sets card (for current exercise) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_logged_sets"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardElevation="0dp"
                app:cardCornerRadius="16dp" app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tv_sets_header"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/layout_logged_sets"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom action bar: navigation + timer button -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingTop="8dp" android:paddingBottom="12dp"
        android:background="?attr/colorSurface">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev_exercise"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Back"
            android:textSize="13sp" />
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_timer_recall"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="⏱"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:layout_marginEnd="8dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_exercise"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Next"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Item 9: calculator-style weight keypad (+/− only). Hidden until the weight field is tapped;
         the field holds the live resolved total so a plain number can still just be typed. -->
    <LinearLayout
        android:id="@+id/layout_weight_keypad"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="6dp" android:paddingBottom="10dp"
        android:visibility="gone">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant" android:layout_marginBottom="6dp" />

        <TextView android:id="@+id/tv_kp_expr"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="end" android:paddingEnd="8dp"
            android:minHeight="20dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_7"
                style="@style/Widget.Material3.Button.TonalButton" android:text="7"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_8"
                style="@style/Widget.Material3.Button.TonalButton" android:text="8"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_9"
                style="@style/Widget.Material3.Button.TonalButton" android:text="9"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_back"
                style="@style/Widget.Material3.Button.OutlinedButton" android:text="⌫"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_4"
                style="@style/Widget.Material3.Button.TonalButton" android:text="4"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_5"
                style="@style/Widget.Material3.Button.TonalButton" android:text="5"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_6"
                style="@style/Widget.Material3.Button.TonalButton" android:text="6"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_minus"
                style="@style/Widget.Material3.Button" android:text="−" android:textSize="20sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_1"
                style="@style/Widget.Material3.Button.TonalButton" android:text="1"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_2"
                style="@style/Widget.Material3.Button.TonalButton" android:text="2"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_3"
                style="@style/Widget.Material3.Button.TonalButton" android:text="3"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_kp_plus"
                style="@style/Widget.Material3.Button" android:text="+" android:textSize="20sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
