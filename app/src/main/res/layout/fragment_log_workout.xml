                style="@style/Widget.Material3.Button.TonalButton" android:text="."
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:layout_margin="3dp" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
