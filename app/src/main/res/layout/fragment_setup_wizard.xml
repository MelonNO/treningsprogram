<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btn_wizard_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tv_wizard_step_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Auros.Eyebrow"
                android:text="STEP 1 OF 5" />

            <TextView
                android:id="@+id/tv_wizard_step_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_wizard_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_wizard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:trackCornerRadius="4dp"
        app:trackColor="?attr/colorOutlineVariant" />

    <!-- Step flipper -->
    <ViewFlipper
        android:id="@+id/step_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ─── Step 0: Goal ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What is your main fitness goal?"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This shapes rep ranges, rest times, and weekly volume."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_goal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="28dp">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_goal_hypertrophy"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hypertrophy"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_goal_strength"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strength" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_goal_endurance"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Endurance" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_goal_weightloss"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weight Loss" />
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Experience level"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_experience"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_exp_beginner"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beginner" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_exp_intermediate"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intermediate"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_exp_advanced"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Advanced" />
                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─── Step 1: Schedule ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="When do you want to train?"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="6dp" />

                <!-- B08: mode toggle. OFF (default) = pick specific rest days; ON = pick a number of
                     training days and let the AI choose which days are rest. -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_let_ai_choose_days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Let the AI choose which days to train"
                    android:checked="false"
                    android:layout_marginBottom="14dp" />

                <!-- REST-DAY mode (default): user selects rest days; training fills the rest. -->
                <LinearLayout
                    android:id="@+id/layout_rest_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pick your rest days — we'll plan training on every other day."
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_rest_days"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_1" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_2" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_3" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wed" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_4" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_5" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_6" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:checked="true" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_rest_7" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sun" android:checked="true" />
                    </com.google.android.material.chip.ChipGroup>
                    <TextView
                        android:id="@+id/tv_training_days_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginTop="10dp" />
                </LinearLayout>

                <!-- COUNT mode: user picks a number of training days; AI chooses which are rest. -->
                <LinearLayout
                    android:id="@+id/layout_count_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="32dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How many days per week can you train? (the AI picks which days)"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_days"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">
                        <com.google.android.material.chip.Chip android:id="@+id/chip_days_2" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 days" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_days_3" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3 days" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_days_4" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4 days" android:checked="true" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_days_5" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 days" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip_days_6" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6 days" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How long is each session?"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dur_30" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30 min" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dur_45" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="45 min" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dur_60" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60 min" android:checked="true" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dur_75" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="75 min" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dur_90" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="90 min" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_dur_custom"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custom" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_custom_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Minutes per session"
                    android:visibility="gone"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_custom_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─── Step 2: Equipment ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select your gym setup"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose a preset or create your own. We only plan exercises that match your equipment."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:id="@+id/layout_equip_presets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_preset"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Create new preset" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─── Step 3: Training Profile ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tell us about yourself"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This helps the AI tailor exercises and load to your specific situation."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="28dp" />

                <!-- Injuries -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Auros.Eyebrow"
                    android:text="Current injuries or physical limitations"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="e.g. “bad knee — deep squats aggravate it.” Say which body part, what movement or load aggravates it, and what to avoid, so the AI can act on it."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_wizard_injuries"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:hint="None" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_wizard_severity_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    style="@style/Widget.Auros.Eyebrow"
                    android:text="How much does it limit you?"
                    android:layout_marginBottom="6dp" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_wizard_severity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:singleSelection="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_wizard_severity_mild" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mild" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_wizard_severity_moderate" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moderate" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_wizard_severity_severe" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Severe" />
                </com.google.android.material.chip.ChipGroup>
                <TextView
                    android:id="@+id/tv_wizard_severity_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="Mild = barely limits me · Moderate = limits some movements · Severe = must avoid entirely"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp" />

                <!-- Priority muscles -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Auros.Eyebrow"
                    android:text="Muscle groups to prioritise"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select any you want extra volume on"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_priority_muscles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:singleSelection="false">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_chest" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chest" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_back" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Back" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_shoulders" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shoulders" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_arms" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Arms" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_legs" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Legs" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_glutes" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Glutes" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_muscle_core" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Core" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Disliked / can't-do exercises -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Auros.Eyebrow"
                    android:text="Exercises you dislike or can't do"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="e.g. burpees, barbell squats, overhead press"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_wizard_dislikes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:hint="None" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Cardio preference -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Separate cardio days"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textColor="?attr/colorOnSurface" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Never mix cardio and strength training on the same day"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_cardio_wizard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─── Step 4: API Key ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect Claude AI"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Claude analyses your workout history and generates a personalised weekly program. Your key is stored securely on this device and never shared."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="24dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Claude API Key (sk-ant-…)"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_wizard_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get a free API key at console.anthropic.com"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─── Step 5: Generating ─── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Generating state -->
            <LinearLayout
                android:id="@+id/layout_generating"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">
                <ProgressBar
                    android:id="@+id/progress_generating"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginBottom="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Building your program…"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tv_generating_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Claude is analysing your profile and creating a science-based weekly plan."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />
                <!-- P5: rotating, informative wait copy below the real status line -->
                <TextView
                    android:id="@+id/tv_generating_tip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Success state -->
            <LinearLayout
                android:id="@+id/layout_success"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="56sp"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="16dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your program is ready!"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tv_success_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:layout_marginBottom="32dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_go_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Let's Go" />
            </LinearLayout>

            <!-- Error state -->
            <LinearLayout
                android:id="@+id/layout_gen_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Something went wrong"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tv_gen_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:layout_marginBottom="24dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry_generate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Retry" />
            </LinearLayout>

        </FrameLayout>

    </ViewFlipper>

    <!-- Bottom action row -->
    <LinearLayout
        android:id="@+id/layout_wizard_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="end">

        <com.migul.treningsprogram.ui.widget.GradientButton
            android:id="@+id/btn_wizard_next"
            style="@style/Widget.Auros.Button.Gradient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next"
            app:icon="@drawable/ic_arrow_up_right"
            app:iconGravity="textEnd" />

    </LinearLayout>

</LinearLayout>
