<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.migul.treningsprogram.ui.home.HomeFragment"
        android:label="@string/home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_log"
            app:destination="@id/logWorkoutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_setup_wizard"
            app:destination="@id/setupWizardFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/setupWizardFragment"
        android:name="com.migul.treningsprogram.ui.setup.SetupWizardFragment"
        android:label="Setup"
        tools:layout="@layout/fragment_setup_wizard" />

    <fragment
        android:id="@+id/logWorkoutFragment"
        android:name="com.migul.treningsprogram.ui.log.LogWorkoutFragment"
        android:label="@string/log_workout"
        tools:layout="@layout/fragment_log_workout">
        <argument
            android:name="sessionId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="dayOfWeek"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.migul.treningsprogram.ui.history.HistoryFragment"
        android:label="@string/history"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/programFragment"
        android:name="com.migul.treningsprogram.ui.program.ProgramFragment"
        android:label="@string/program"
        tools:layout="@layout/fragment_program">
        <action
            android:id="@+id/action_program_to_log"
            app:destination="@id/logWorkoutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_settings">
        <action android:id="@+id/action_settings_to_training"
            app:destination="@id/settingsTrainingFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_ai"
            app:destination="@id/settingsAiFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_debug"
            app:destination="@id/settingsDebugFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_backup"
            app:destination="@id/settingsBackupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_about"
            app:destination="@id/settingsAboutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_library"
            app:destination="@id/exerciseLibraryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_to_weekly_summary"
            app:destination="@id/weeklySummaryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/settingsAboutFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsAboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_settings_about" />

    <fragment
        android:id="@+id/settingsTrainingFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsTrainingFragment"
        android:label="Training Profile"
        tools:layout="@layout/fragment_settings_training">
        <action android:id="@+id/action_settings_training_to_gym_presets"
            app:destination="@id/gymPresetsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/settingsAiFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsAiFragment"
        android:label="AI &amp; Program"
        tools:layout="@layout/fragment_settings_ai" />

    <fragment
        android:id="@+id/settingsPromptLogFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsPromptLogFragment"
        android:label="Prompt Log"
        tools:layout="@layout/fragment_settings_prompt_log" />

    <fragment
        android:id="@+id/settingsRejectionLogFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsRejectionLogFragment"
        android:label="Rejection Log"
        tools:layout="@layout/fragment_settings_rejection_log" />

    <fragment
        android:id="@+id/settingsDebugFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsDebugFragment"
        android:label="Debug"
        tools:layout="@layout/fragment_settings_debug">
        <action android:id="@+id/action_settings_debug_to_prompt_log"
            app:destination="@id/settingsPromptLogFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_debug_to_rejection_log"
            app:destination="@id/settingsRejectionLogFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_debug_to_unrecognized"
            app:destination="@id/settingsUnrecognizedFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_settings_debug_to_crash_log"
            app:destination="@id/settingsCrashLogFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/settingsCrashLogFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsCrashLogFragment"
        android:label="Crash Log"
        tools:layout="@layout/fragment_settings_crash_log" />

    <fragment
        android:id="@+id/settingsUnrecognizedFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsUnrecognizedFragment"
        android:label="Unrecognized Exercises"
        tools:layout="@layout/fragment_settings_unrecognized" />

    <fragment
        android:id="@+id/settingsBackupFragment"
        android:name="com.migul.treningsprogram.ui.settings.SettingsBackupFragment"
        android:label="Backup &amp; Data"
        tools:layout="@layout/fragment_settings_backup" />

    <fragment
        android:id="@+id/gymPresetsFragment"
        android:name="com.migul.treningsprogram.ui.settings.GymPresetsFragment"
        android:label="Gym Presets"
        tools:layout="@layout/fragment_gym_presets" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.migul.treningsprogram.ui.profile.ProfileFragment"
        android:label="@string/profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/recapTrendsFragment"
        android:name="com.migul.treningsprogram.ui.history.RecapTrendsFragment"
        android:label="Trends"
        tools:layout="@layout/fragment_recap_trends">
        <argument
            android:name="exerciseName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="sessionDateMs"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

    <fragment
        android:id="@+id/exerciseLibraryFragment"
        android:name="com.migul.treningsprogram.ui.library.ExerciseLibraryFragment"
        android:label="Exercise Library"
        tools:layout="@layout/fragment_exercise_library">
        <action
            android:id="@+id/action_library_to_detail"
            app:destination="@id/exerciseDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/exerciseDetailFragment"
        android:name="com.migul.treningsprogram.ui.library.ExerciseDetailFragment"
        android:label="Exercise"
        tools:layout="@layout/fragment_exercise_detail">
        <argument
            android:name="exerciseId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/weeklySummaryFragment"
        android:name="com.migul.treningsprogram.ui.summary.WeeklySummaryFragment"
        android:label="Coach Summary"
        tools:layout="@layout/fragment_weekly_summary" />

</navigation>
